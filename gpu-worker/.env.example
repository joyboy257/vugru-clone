# PropFrame GPU Worker — Environment Variables
# Copy to .env and fill in your values

# ── Railway PostgreSQL ────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:your_password@postgres.railway.internal:5432/railway

# ── Cloudflare R2 ──────────────────────────────────────────────────
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET=vugru-media
R2_PUBLIC_URL=https://your-public-r2-url.com

# ── AI / Video Generation ─────────────────────────────────────────
# Replace with your actual AI video model endpoint
VIDEO_MODEL_API_URL=https://api.your-ai-provider.com/v1/video/generate
VIDEO_MODEL_API_KEY=your_api_key_here

# ── FFmpeg (installed on the worker machine) ──────────────────────
FFMPEG_PATH=/usr/bin/ffmpeg
FFPROBE_PATH=/usr/bin/ffprobe

# ── Worker Config ──────────────────────────────────────────────────
POLL_INTERVAL_MS=3000
LOG_LEVEL=info
